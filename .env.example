# ──────────────────────────────────────────────────────
# .env.example — Template for local development
#
# 1. Copy this file:  cp .env.example .env
# 2. Replace the value below with your real Gemini API key
# 3. Get a free key at: https://aistudio.google.com/app/apikey
#
# ⚠️  NEVER commit your .env file to GitHub
#      .env is already in .gitignore — keep it that way
# ──────────────────────────────────────────────────────

GEMINI_API_KEY=your_gemini_api_key_here

# ── FOR STREAMLIT CLOUD DEPLOYMENT ──────────────────
# Do NOT use this .env file on Streamlit Cloud.
# Instead go to: App Settings → Secrets and add:
#
#   GEMINI_API_KEY = "AIza..."
#
# ────────────────────────────────────────────────────
